generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Merchant {
  id        String   @id @default(cuid())
  name      String
  legalName String?
  taxId     String?  @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
}

model Branch {
  id        String     @id @default(cuid())
  merchantId String
  merchant  Merchant   @relation(fields: [merchantId], references: [id])
  name      String
  code      String
  address   String?
  status    String     @default("ACTIVE")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  terminals Terminal[]
  tickets   Ticket[]

  @@unique([merchantId, code])
  @@index([merchantId])
}

model Terminal {
  id        String   @id @default(cuid())
  name      String
  code      String
  slug      String   @unique
  status    String   @default("ACTIVE")
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets   Ticket[]

  @@index([branchId])
  @@unique([branchId, code])
}

model Ticket {
  id                  String        @id @default(cuid())
  folio               String
  status              String        @default("DRAFT")
  subtotalCents       Int
  taxCents            Int           @default(0)
  totalCents          Int
  currency            String        @default("MXN")
  paymentMethod       String        @default("OTHER")
  branchId            String
  terminalId          String
  branch              Branch        @relation(fields: [branchId], references: [id])
  terminal            Terminal      @relation(fields: [terminalId], references: [id])
  activatedAt         DateTime?
  activationExpiresAt DateTime?
  claimedAt           DateTime?
  claimedDeviceId     String?
  accessToken         String?       @unique
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  items               TicketItem[]
  events              TicketEvent[]

  @@unique([branchId, folio])
  @@index([terminalId, status, activationExpiresAt])
}

model TicketItem {
  id             String @id @default(cuid())
  ticketId       String
  ticket         Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  name           String
  quantity       Int
  unitPriceCents Int
  lineTotalCents Int

  @@index([ticketId])
}

model TicketEvent {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type         String
  deviceId     String?
  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([ticketId, createdAt])
}
